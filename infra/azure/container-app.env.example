# Copy to infra/azure/container-app.env and fill values locally.
# Do not commit the filled file.

RESOURCE_GROUP=mission-bazaar-rg
LOCATION=koreacentral
CONTAINER_APP_ENV=mission-bazaar-env
CONTAINER_APP_NAME=mission-bazaar-kiosk

# Use GHCR to avoid Azure Container Registry fixed cost.
IMAGE=ghcr.io/<github-owner>/<repo>/web:latest

# If the GHCR package is private, set these.
# If the package is public, leave both empty.
GHCR_USERNAME=
GHCR_TOKEN=

# Keep min replicas at 0 for near-zero idle cost.
MIN_REPLICAS=0
MAX_REPLICAS=5

EVENT_CODE=mission-bazaar-2026
COOKIE_SECRET=<generate-a-long-random-secret>

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
